# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
__pycache__/
*.pyc

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# local Claude Code / agent-skill tooling artifacts (installed by
# `vercel integration add`), not app code
.claude/
.agents/
skills-lock.json

# AI-assistant instruction files — living local docs updated as needed, but
# not tracked in the repo itself (untracked 2026-07-22)
CLAUDE.md
AGENTS.md
SKILL.md

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# WhatsApp export (real member names, numbers, private conversations) —
# never commit, ever. See SKILL.md's data handling rules.
Media/

# extras/ (data, PDFs, effort log, and both generator scripts) stays fully
# local — generate_design_pdf.py and generate_security_pdf.py are dev-only
# authoring tools, not part of the public repo (see SKILL.md's data handling
# rules)
extras/*

# docs/User Guide.md/.pdf + its screenshots stay local too (#91, reversed
# 2026-07-23 from the issue's original "should be public" plan) — a living
# doc updated as needed, same untracked convention as extras/
docs/*
