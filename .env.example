# Optional, cosmetic only: silences dotenv's own promotional "tip" line
# printed on every load (unrelated to Prisma/Supabase).
DOTENV_CONFIG_QUIET="true"

# Preferred: pull from Vercel, which auto-provisions POSTGRES_PRISMA_URL
# (pooled, for app queries) and POSTGRES_URL_NON_POOLING (direct, for
# migrations) correctly-formatted — no manual copying, no password
# percent-encoding to get wrong.
#   vercel env pull .env
#   vercel env pull .env.local
# This pulls the Development-scoped values, which point at a SEPARATE,
# non-production Supabase project (#52) — never the live production one.
# Preview deployments use the same non-production project; only Production
# deployments use the real one. See SKILL.md's Deployment section for the
# full setup (schema-sync process, the pooler-vs-direct-host gotcha, and
# why the connecting role there is `app_owner`, not `postgres`).
#
# Fallback (no Vercel project linked): set these two by hand from
# Supabase's Connect dialog (Project -> Connect -> Direct tab), pointed at
# the non-production project, not the live one. If your database password
# has special characters, percent-encode them first — Supabase's own
# dialog warns about this — or the URL won't parse.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

APP_URL="http://localhost:3000"

# Provisioned by the same Vercel Supabase Marketplace integration as the
# POSTGRES_* vars above — used for Supabase Auth (see src/lib/supabase/).
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is safe to expose to the browser;
# SUPABASE_SECRET_KEY must never be, and is only read server-side
# (src/lib/supabase/admin.ts) for admin.* operations (invite, role sync,
# forced sign-out, deletion).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""

# Only used if Supabase's own SMTP isn't yet configured to use Resend
# (Project Settings -> Auth -> SMTP in the Supabase dashboard) — not read
# by any code path today, kept for any future direct transactional email
# (see src/lib/email.ts, issue #11).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Umoja Voices <onboarding@resend.dev>"
