# Preferred: connect the Supabase integration on the Vercel project
# (Storage/Marketplace tab), which auto-provisions POSTGRES_PRISMA_URL
# (pooled, for app queries) and POSTGRES_URL_NON_POOLING (direct, for
# migrations) correctly-formatted — no manual copying, no password
# percent-encoding to get wrong. Pull them locally with:
#   vercel env pull .env
#
# Fallback (no Vercel-Supabase integration): set these two by hand from
# Supabase's Connect dialog (Project -> Connect -> Direct tab). If your
# database password has special characters, percent-encode them first —
# Supabase's own dialog warns about this — or the URL won't parse.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""
